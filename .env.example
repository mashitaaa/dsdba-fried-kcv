# =============================================================================
# .env.example — DSDBA Credential Template
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# .env is in .gitignore — NEVER commit it [FR-NLP-005, NFR-Security]
# In production: use HuggingFace Spaces Secrets, not .env
# =============================================================================

# Qwen 2.5 API Key (FR-NLP-005)
# Source: HuggingFace Spaces secret used by config.yaml (HF_API_KEY)
HF_API_KEY="YOUR_HF_API_KEY_HERE"

# HuggingFace Token (FR-CV-007, FR-DEP-001)
# Get from: https://huggingface.co/settings/tokens (read + write)
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# HuggingFace Model Repo ID (FR-CV-007)
# Format: username/model-name
HF_MODEL_REPO="your_username/dsdba-efficientnet-b4"

# HuggingFace Spaces Repo ID (FR-DEP-001)
# Format: username/space-name
HF_SPACE_REPO="your_username/dsdba-deepfake-detector"